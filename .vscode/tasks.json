{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "deno: dev",
      "type": "shell",
      "command": "deno task dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "(?=)",
          "endsPattern": "Local:"
        }
      }
    },
    {
      "label": "deno: build",
      "type": "shell",
      "command": "deno task build",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
